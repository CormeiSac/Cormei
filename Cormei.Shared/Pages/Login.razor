@page "/"
@page "/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Components
@using Cormei.Core.Interfaces.Login
@using Cormei.Core.Services.Login
@inject IAuthService AuthService
@inject AuthState AuthState
@inject NavigationManager NavigationManager

<PageTitle>Iniciar sesión · CORMEI</PageTitle>

<main class="flex h-screen w-full font-sans text-slate-800 antialiased selection:bg-cormei selection:text-white">

    <div class="relative flex h-full w-full flex-col overflow-hidden bg-[#F8F9FA]">

        <section class="relative z-10 w-full shrink-0 h-[26vh] min-h-[190px] sm:h-[30%] bg-slate-900">
            <img src="_content/Cormei.Shared/images/bg_login.png" alt="Industria Cormei"
                 class="absolute inset-0 h-full w-full object-cover object-center" />

            <img src="_content/Cormei.Shared/images/ic_logo_white.png" alt="Logo CORMEI"
                 class="absolute left-6 top-6 h-10 w-auto object-contain" />

            <div class="absolute bottom-0 left-0 w-full p-6 pb-5">
                <p class="text-white text-[13px] leading-tight font-medium drop-shadow-md">
                    Ingrese su nombre de usuario y contraseña<br>
                    para acceder a su cuenta.
                </p>
            </div>
        </section>

        <section class="relative flex w-full flex-grow flex-col items-center overflow-y-auto px-7 pt-7 pb-6">
          <div class="flex w-full max-w-[420px] flex-grow flex-col">

            <EditForm Model="modelo" OnValidSubmit="ManejarLogin" class="w-full space-y-4">

                <div>
                    <label class="mb-1.5 block text-sm font-bold text-black">Nombre de usuario</label>
                    <div class="group relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                            <svg class="h-[18px] w-[18px] text-black" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                            </svg>
                        </div>
                        <input type="text" placeholder="Nombre de usuario" @bind="modelo.Usuario" @bind:event="oninput" disabled="@estaCargando" required
                               class="@($"w-full rounded-md border {ClaseBorde} bg-white py-2.5 pl-10 pr-4 text-[14px] text-gray-800 placeholder-gray-500 shadow-sm outline-none transition-all duration-200 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-400")" />
                    </div>
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-bold text-black">Contraseña</label>
                    <div class="group relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                            <svg class="h-[18px] w-[18px] text-black" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/>
                            </svg>
                        </div>
                        <input type="@(mostrarPassword ? "text" : "password")" placeholder="Ingrese la contraseña" @bind="modelo.Password" @bind:event="oninput" disabled="@estaCargando" required
                               class="@($"w-full rounded-md border {ClaseBorde} bg-white py-2.5 pl-10 pr-10 text-[14px] text-gray-800 placeholder-gray-500 shadow-sm outline-none transition-all duration-200 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-gray-400")" />
                        
                        <button type="button" @onclick="() => mostrarPassword = !mostrarPassword" disabled="@estaCargando" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 transition-colors hover:text-gray-600 focus:outline-none disabled:cursor-not-allowed disabled:opacity-50">
                            @if (mostrarPassword)
                            {
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" fill="none" />
                                    <line x1="3" y1="3" x2="21" y2="21" />
                                </svg>
                            }
                            else
                            {
                                <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div @key="errorTick" class="animate-shake flex items-center gap-2 rounded-md bg-red-50 px-3 py-2 text-xs font-semibold text-red-600">
                        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008v.008H12v-.008zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>@mensajeError</span>
                    </div>
                }

                <div class="pt-2">
                    <button type="submit" disabled="@estaCargando"
                            class="relative flex w-full items-center justify-center rounded-md bg-[#be1e2d] px-6 py-2.5 text-[15px] font-bold tracking-wide text-white transition-all duration-300 hover:bg-[#a11925] focus:outline-none focus:ring-4 focus:ring-red-600/30 disabled:opacity-70">
                        @if (estaCargando)
                        {
                            <span class="flex items-center gap-2">
                                <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v2a6 6 0 00-6 6H4z"></path>
                                </svg>
                                Autenticando...
                            </span>
                        }
                        else
                        {
                            <span>Iniciar Sesión</span>
                        }
                    </button>
                </div>
            </EditForm>

            <div class="mt-auto pt-6 text-center">
                <p class="text-[12px] font-medium text-gray-500">2026 CORMEI Rights reserved</p>
            </div>
          </div>
        </section>

        <button type="button" title="Más opciones" class="absolute bottom-6 right-6 z-50 flex h-[48px] w-[48px] items-center justify-center rounded-full border border-gray-200 bg-white shadow-[0_4px_14px_rgba(0,0,0,0.12)] transition-transform duration-300 hover:scale-105">
            <svg class="h-6 w-6 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="3" width="7" height="7" rx="1.5" />
                <rect x="5.5" y="5.5" width="2" height="2" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="14" y="3" width="7" height="7" rx="1.5" />
                <rect x="16.5" y="5.5" width="2" height="2" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="3" y="14" width="7" height="7" rx="1.5" />
                <rect x="5.5" y="16.5" width="2" height="2" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="14" y="14" width="2.5" height="2.5" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="18.5" y="14" width="2.5" height="2.5" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="14" y="18.5" width="2.5" height="2.5" fill="currentColor" stroke="none" rx="0.5" />
                <rect x="18.5" y="18.5" width="2.5" height="2.5" fill="currentColor" stroke="none" rx="0.5" />
            </svg>
        </button>
    </div>
</main>

@code {
    private LoginModelo modelo = new LoginModelo();
    private bool estaCargando = false;
    private bool mostrarPassword = false;
    private string mensajeError = string.Empty;
    private int errorTick = 0;

    private string ClaseBorde => string.IsNullOrEmpty(mensajeError)
        ? "border-gray-300 focus:border-gray-400 focus:ring-gray-200"
        : "border-red-400 focus:border-red-500 focus:ring-red-100";

    private async Task ManejarLogin()
    {
        mensajeError = string.Empty;

        if (string.IsNullOrWhiteSpace(modelo.Usuario) || string.IsNullOrWhiteSpace(modelo.Password))
        {
            mensajeError = "Usuario y contraseña son requeridos.";
            errorTick++;
            return;
        }

        estaCargando = true;
        try
        {
            var resultado = await AuthService.Login(modelo.Usuario, modelo.Password);
            AuthState.SetSession(resultado);

            StateHasChanged();

            await Task.Delay(1200);
            NavigationManager.NavigateTo("/Home");
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
            errorTick++;
        }
        finally
        {
            estaCargando = false;
        }
    }

    private class LoginModelo
    {
        public string Usuario { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}