@page "/marcacion-remota"
@layout LoginLayout
@using Cormei.Core.Services.Login
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Marcación remota · CORMEI</PageTitle>

<div class="flex h-screen w-full flex-col overflow-hidden bg-white pt-[env(safe-area-inset-top)] font-sans text-slate-700">

    <header class="relative flex h-16 shrink-0 items-center justify-center border-b border-slate-200 bg-white px-4 sm:px-6">
        <button type="button" @onclick="Volver" title="Volver" class="absolute left-4 flex h-9 w-9 items-center justify-center rounded-lg hover:bg-slate-100">
            <img src="_content/Cormei.Shared/images/ic_header_back.png" alt="Volver" class="h-5 w-5 object-contain" />
        </button>
        <h1 class="text-xl font-bold text-cormei">Remote Dial</h1>
    </header>

    <main class="flex-1 overflow-y-auto p-4 sm:p-6">
        <div class="mx-auto flex max-w-md flex-col gap-4">

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Fecha</p>
                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                    <input type="date" @bind="fecha" class="w-full bg-transparent text-sm text-slate-700 outline-none" />
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Campus</p>
                <div class="relative flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                    <select @bind="campusSeleccionado" disabled="@cargandoSedes" class="w-full appearance-none bg-transparent pr-6 text-sm text-slate-700 outline-none">
                        <option value="0" disabled selected>@(cargandoSedes ? "Cargando campus..." : "Seleccionar campus")</option>
                        @foreach (var sede in sedes)
                        {
                            <option value="@sede.IdBiometrico">@sede.Sede</option>
                        }
                    </select>
                    <svg class="pointer-events-none absolute right-3 h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Número de documento</p>
                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <input type="text" @bind="numeroDocumento" disabled class="w-full bg-transparent text-sm text-slate-700 outline-none disabled:cursor-not-allowed" />
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Nombre</p>
                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                    <input type="text" @bind="nombre" disabled class="w-full bg-transparent text-sm text-slate-700 outline-none disabled:cursor-not-allowed" />
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Apellido</p>
                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                    <input type="text" @bind="apellido" disabled class="w-full bg-transparent text-sm text-slate-700 outline-none disabled:cursor-not-allowed" />
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Ubicación</p>
                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    <input type="text" @bind="ubicacion" @bind:event="oninput" class="w-full bg-transparent text-sm text-slate-700 outline-none" />
                    <img src="_content/Cormei.Shared/images/ic_remote_dial_google_map.png" alt="Google Maps" class="h-6 w-6 shrink-0 object-contain" />
                </div>
            </div>

            <div>
                <p class="mb-2 text-sm font-bold text-slate-900">Razón</p>
                <textarea @bind="razon" @bind:event="oninput" rows="4" placeholder="Ingrese el motivo aquí"
                          class="w-full resize-none rounded-xl border border-slate-300 bg-white px-3 py-3 text-sm text-slate-700 outline-none placeholder-slate-400"></textarea>
            </div>

            <div>
                <p class="text-sm font-bold text-slate-900">Tomar foto</p>
                <p class="mt-1 text-xs text-slate-400">En la foto debe mostar el sitio de trabajo y la persona que marca</p>

                <div class="relative mt-2 flex h-32 w-32 flex-col items-center justify-center overflow-hidden rounded-xl border border-slate-300 bg-white">
                    <InputFile OnChange="OnFotoSeleccionada" accept="image/*" capture="environment" class="absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0" />

                    @if (fotoPreviewUrl is not null)
                    {
                        <img src="@fotoPreviewUrl" alt="Foto de marcación" class="h-full w-full object-cover" />
                    }
                    else
                    {
                        <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.174C3.023 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.773-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.174 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.043 48.774 48.774 0 00-4.352 0 2.192 2.192 0 00-1.736 1.043l-.821 1.316z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" />
                        </svg>
                        <p class="mt-1 text-sm text-slate-400">Subir</p>
                    }
                </div>
            </div>

            @if (mensajeResultado is not null)
            {
                <div class="@($"rounded-lg px-4 py-3 text-sm font-semibold {(envioExitoso == true ? "bg-green-50 text-green-600" : "bg-red-50 text-red-600")}")">
                    @mensajeResultado
                </div>
            }

            <button type="button" disabled="@(!FormularioValido || enviando)" @onclick="Registrar"
                    class="@($"mt-2 w-full rounded-xl py-3 text-sm font-bold text-white transition {(FormularioValido && !enviando ? "bg-cormei hover:bg-cormei/90" : "cursor-not-allowed bg-slate-400")}")">
                @(enviando ? "Enviando..." : "Registrar")
            </button>
        </div>
    </main>
</div>
