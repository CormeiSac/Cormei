@page "/actividades"

<PageTitle>Actividades · CORMEI</PageTitle>

<div class="flex h-full flex-col">
    <div class="mx-auto flex w-full max-w-md flex-1 flex-col gap-4 overflow-hidden">

        <div class="flex overflow-hidden rounded-xl border border-slate-200">
            <button type="button" @onclick="() => SeleccionarPestana(Pestana.MasUsadas)" class="@ClaseTab(Pestana.MasUsadas)">Más usadas</button>
            <button type="button" @onclick="() => SeleccionarPestana(Pestana.RestoDeLista)" class="@ClaseTab(Pestana.RestoDeLista)">Resto de lista</button>
            <button type="button" @onclick="() => SeleccionarPestana(Pestana.Favoritas)" class="@ClaseTab(Pestana.Favoritas)">Actividad favorita</button>
        </div>

        <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-100 px-3 py-2.5">
            <svg class="h-5 w-5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            <input type="text" placeholder="Buscar actividades" @bind="textoBusqueda" @bind:event="oninput"
                   class="w-full bg-transparent text-sm text-slate-700 placeholder-slate-400 outline-none" />
            <button type="button" @onclick="() => textoBusqueda = string.Empty" class="shrink-0 text-sm font-medium text-slate-400 hover:text-cormei">Cancelar</button>
        </div>

        <div class="flex flex-1 flex-col gap-4 overflow-y-auto pb-2">
            @if (cargando)
            {
                <p class="py-10 text-center text-sm text-slate-400">Cargando actividades...</p>
            }
            else if (mensajeError is not null)
            {
                <div class="rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-600">@mensajeError</div>
            }
            else
            {
            @foreach (var actividad in ActividadesFiltradas)
            {
                <div class="cursor-pointer rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md" @onclick="() => AbrirDetalle(actividad)">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex min-w-0 flex-1 items-start gap-2.5">
                            <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                            </svg>
                            <div class="min-w-0">
                                <p class="break-words font-bold text-cormei">@actividad.Nombre</p>
                                @if (!string.IsNullOrWhiteSpace(actividad.Descripcion))
                                {
                                    <p class="break-words text-sm font-semibold text-slate-900">@actividad.Descripcion</p>
                                }
                            </div>
                        </div>
                        <button type="button" @onclick="() => AlternarFavorito(actividad)" @onclick:stopPropagation="true" class="shrink-0 text-cormei">
                            @if (actividad.EsFavorito)
                            {
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 21s-8-4.5-8-11a5.5 5.5 0 0111-2.5A5.5 5.5 0 0120 10c0 6.5-8 11-8 11z" />
                                </svg>
                            }
                            else
                            {
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                                </svg>
                            }
                        </button>
                    </div>

                    <div class="mt-2.5 flex items-center gap-4 text-sm font-semibold text-slate-800">
                        <span class="flex items-center gap-1.5">
                            <svg class="h-5 w-5 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                            </svg>
                            @actividad.Repeticiones
                        </span>
                        <span class="flex items-center gap-1.5">
                            <svg class="h-5 w-5 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            @actividad.TiempoMinutos
                        </span>
                    </div>

                    <div class="mt-2 flex items-center gap-1.5 text-sm text-slate-500">
                        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                        </svg>
                        <span>@(string.IsNullOrWhiteSpace(actividad.Comentario) ? "-" : actividad.Comentario)</span>
                    </div>
                </div>
            }

            @if (!ActividadesFiltradas.Any())
            {
                <p class="py-10 text-center text-sm text-slate-400">No se encontraron actividades.</p>
            }
            }
        </div>
    </div>

    <div class="-mx-4 -mb-4 mt-4 flex text-xs sm:-mx-6 sm:-mb-6 lg:-mx-8 lg:-mb-8" style="padding-bottom: env(safe-area-inset-bottom);">
        <div class="flex-1 bg-slate-900 px-4 py-3 text-white">
            <p class="font-semibold">Tiempo mínimo total a registrar por día</p>
            <p class="mt-1">LUN-VIE: @MinutosMinimosLunesAViernes min (8.5 horas)</p>
            <p>SAB: @MinutosMinimosSabado min (5.5 horas)</p>
        </div>
        <div class="@ClaseFooterTotales">
            <p class="font-semibold">Minutos totales: @MinutosTotales</p>
            <p class="mt-1 font-semibold">Horas totales: @HorasTotales.ToString("0.0")</p>
        </div>
    </div>
</div>