@page "/actividades/detalle/{IdActividad:int}"
@layout LoginLayout

<PageTitle>Registro de actividad · CORMEI</PageTitle>

<div class="flex h-screen w-full flex-col overflow-hidden bg-white pt-[env(safe-area-inset-top)] font-sans text-slate-700">

    <header class="relative flex h-16 shrink-0 items-center justify-center border-b border-slate-200 bg-white px-4 sm:px-6">
        <button type="button" @onclick="Volver" title="Volver" class="absolute left-4 flex h-9 w-9 items-center justify-center rounded-lg hover:bg-slate-100">
            <img src="_content/Cormei.Shared/images/ic_header_back.png" alt="Volver" class="h-5 w-5 object-contain" />
        </button>
        <h1 class="text-lg font-bold uppercase text-cormei">Registro de Actividad</h1>
    </header>

    <main class="flex-1 overflow-y-auto p-4 sm:p-6">
        @if (cargando)
        {
            <p class="text-sm text-slate-400">Cargando actividad...</p>
        }
        else if (mensajeError is not null)
        {
            <div class="rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-600">@mensajeError</div>
        }
        else if (actividad is null)
        {
            <p class="text-sm text-slate-400">No se encontró la actividad.</p>
        }
        else
        {
            <div class="mx-auto flex max-w-md flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">

                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                    </svg>
                    <span class="w-full break-words text-sm font-semibold text-slate-900">@actividad.Nombre</span>
                </div>

                <div class="flex items-start gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                    <span class="w-full break-words text-sm font-bold uppercase text-slate-900">@(string.IsNullOrWhiteSpace(actividad.Descripcion) ? "-" : actividad.Descripcion)</span>
                </div>

                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <input type="number" min="0" @bind="minutos" placeholder="Minutos"
                           class="w-full bg-transparent text-sm text-slate-700 placeholder-slate-400 outline-none" />
                </div>

                <div class="flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                    </svg>
                    <input type="number" min="0" @bind="cantidad" placeholder="Cantidad"
                           class="w-full bg-transparent text-sm text-slate-700 placeholder-slate-400 outline-none" />
                </div>

                <div class="flex items-start gap-3 rounded-xl border border-slate-300 bg-white px-3 py-2.5">
                    <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                    </svg>
                    <textarea @bind="comentario" @bind:event="oninput" rows="5" placeholder="Comentarios"
                              class="w-full resize-none bg-transparent text-sm text-slate-700 placeholder-slate-400 outline-none"></textarea>
                </div>

                @if (mensajeResultado is not null)
                {
                    <div class="rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-600">@mensajeResultado</div>
                }

                <button type="button" disabled="@(!FormularioValido || enviando)" @onclick="Registrar"
                        class="@($"mt-2 w-full rounded-xl py-3 text-sm font-bold text-white transition {(FormularioValido && !enviando ? "bg-cormei hover:bg-cormei/90" : "cursor-not-allowed bg-slate-400")}")">
                    @(enviando ? "Registrando..." : "Registro")
                </button>
            </div>
        }
    </main>
</div>