@page "/Home"
@using Cormei.Core.Services.Login
@inject AuthState AuthState

<PageTitle>Inicio · CORMEI</PageTitle>

<section class="rounded-2xl border border-slate-200/60 bg-white p-6 shadow-sm">
    <h1 class="text-xl font-bold text-slate-800 sm:text-2xl">Bienvenido, @AuthState.Usuario</h1>
    <p class="mt-1 text-sm text-slate-500">Selecciona un módulo del menú para comenzar.</p>
</section>

<section class="mt-6 overflow-hidden rounded-2xl border border-slate-200/60 shadow-sm">
    <img src="_content/Cormei.Shared/images/bg_home.jpg" alt="Cormei"
         class="h-48 w-full object-cover sm:h-64 md:h-80" />
</section>
