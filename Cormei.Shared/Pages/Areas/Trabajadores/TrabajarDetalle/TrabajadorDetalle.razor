@page "/empleados/detalle/{IdTrabajador:int}"
@layout DetalleLayout
@using Cormei.Core.Models.Trabajadores
@using Cormei.Shared.Layout

<PageTitle>Ficha de empleado · CORMEI</PageTitle>


@switch (EstadoActual)
 {
    case EstadoVista.Cargando:
    <p class="text-sm text-slate-400">Cargando ficha...</p>
        break;
    case EstadoVista.Error:
        <div class="rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-600">@mensajeError</div>
        break;
    case EstadoVista.NoEncontrado:
        <p class="text-sm text-slate-400">No se encontró el empleado.</p>
        break;
    case EstadoVista.Listo:
 }
 
@* @if (cargando)
{
    <p class="text-sm text-slate-400">Cargando ficha...</p>
}
else if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-600">@mensajeError</div>
}
else if (empleado is null)
{
    <p class="text-sm text-slate-400">No se encontró el empleado.</p>
}
else
{ *@
    <div class="mx-auto flex max-w-md flex-col items-center text-center">

        <button type="button" @onclick="() => mostrarModalPerfil = true"class="@($"mb-2 h-5 w-5 cursor-pointer rounded-full border-2 p-0 {(EsActivo ? "border-green-500 bg-green-400" : "border-slate-400 bg-slate-300")}")"></button>
        <p class="text-xs font-bold uppercase tracking-widest text-slate-700">@(string.IsNullOrEmpty(empleado.TipoTrabajador) ? "Empleado" : empleado.TipoTrabajador)</p>
        <h2 class="mt-2 w-full break-words text-lg font-bold uppercase text-cormei">@empleado.Nombres</h2>
        <p class="mt-1 w-full break-words text-sm font-medium text-slate-700">@(string.IsNullOrEmpty(empleado.TipoDoc) ? "DNI" : empleado.TipoDoc) : @(string.IsNullOrEmpty(empleado.Documento) ? "—" : empleado.Documento)</p>

        @* Datos generales *@
        <div class="mt-4 w-full space-y-4 rounded-2xl border border-slate-200 bg-white p-4 text-left shadow-sm">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <span class="min-w-0 break-words text-sm font-semibold text-slate-700">@(string.IsNullOrEmpty(empleado.Categoria) ? "" : empleado.Categoria)</span>
            </div>

            <div class="flex min-w-0 items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z" />
            </svg>
            <button type="button" @onclick="() => mostrarModalFechaNacimiento = true"
                    class="min-w-0 cursor-pointer break-words border-0 bg-transparent p-0 text-left text-sm font-bold text-cormei underline decoration-2 underline-offset-2">@(Edad is not null ? $"{Edad} Años" : "")</button>
        </div>

            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex min-w-0 flex-1 items-center gap-3">
                    <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                    </svg>
                    <span class="min-w-0 break-words text-sm font-semibold uppercase text-slate-700">@(string.IsNullOrEmpty(empleado.Sede) ? "—" : empleado.Sede)</span>
                </div>
                <div class="flex min-w-0 flex-1 items-center justify-end gap-2 text-right">
                    <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-12 0v-2.513c0-1.135.845-2.098 1.976-2.192A48.424 48.424 0 0112 8.25c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513m-12 0V21m12-8.379V21" />
                    </svg>
                    <button type="button" @onclick="() => mostrarModalCargo = true"
                            class="min-w-0 cursor-pointer break-words border-0 bg-transparent p-0 text-right text-sm font-bold text-cormei">@(string.IsNullOrEmpty(empleado.Cargo) ? "" : empleado.Cargo)</button>
                </div>
            </div>
        </div>

        @* Contrato *@
        <h3 class="mt-6 w-full text-left text-base font-bold text-cormei">Contract Details:</h3>
        <div class="mt-2 w-full space-y-4 rounded-2xl border border-slate-200 bg-white p-4 text-left shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                    <p class="text-sm text-slate-700">From:</p>
                    <div class="mt-1 flex min-w-0 items-center gap-2">
                        <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                        </svg>
                        <span class="min-w-0 break-words text-sm font-bold text-cormei underline decoration-2 underline-offset-2">@(empleado.FechaInicio?.ToString("dd/MM/yyyy") ?? "")</span>
                    </div>
                </div>
                <div class="min-w-0 flex-1">
                    <p class="text-sm text-slate-700">To:</p>
                    <div class="mt-1 flex min-w-0 items-center gap-2">
                        <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                        </svg>
                        <span class="min-w-0 break-words text-sm font-bold text-cormei underline decoration-2 underline-offset-2">@(empleado.FechaFin?.ToString("dd/MM/yyyy") ?? "")</span>
                    </div>
                </div>
            </div>

            <div class="flex min-w-0 items-center gap-3">
                <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <span class="min-w-0 break-all text-sm font-bold text-cormei underline decoration-2 underline-offset-2">@(string.IsNullOrEmpty(empleado.Telefono) ? "" : empleado.Telefono)</span>
            </div>

            <div class="flex min-w-0 items-center gap-3">
                <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <span class="min-w-0 break-all text-sm text-slate-700">@(string.IsNullOrEmpty(empleado.Correo) ? "" : empleado.Correo)</span>
            </div>

            <div class="flex min-w-0 items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <span class="min-w-0 break-words text-sm text-slate-700"></span>
            </div>
        </div>

        @* Otros *@
        <h3 class="mt-6 w-full text-left text-base font-bold text-cormei">Others:</h3>
        <div class="mt-2 w-full space-y-4 rounded-2xl border border-slate-200 bg-white p-4 text-left shadow-sm">
            <div class="flex min-w-0 items-center gap-3">
                <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c.98.198 1.926.53 2.813.98 1.15.58 2.023 1.526 2.023 2.75V9M4.5 9v-.75A2.25 2.25 0 016.75 6h10.5A2.25 2.25 0 0119.5 8.25V9m-15 0v6.75A2.25 2.25 0 006.75 18h10.5a2.25 2.25 0 002.25-2.25V9m-15 0h15" />
                </svg>
                <span class="min-w-0 break-words text-sm font-semibold uppercase text-slate-700">@(string.IsNullOrEmpty(empleado.SisPension) ? "" : empleado.SisPension)</span>
            </div>

            <div class="flex min-w-0 items-center gap-3">
                <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                </svg>
                <span class="min-w-0 break-words text-sm font-semibold uppercase text-slate-700">@(string.IsNullOrEmpty(empleado.NombreBanco) ? "" : empleado.NombreBanco)</span>
            </div>

            <div class="flex min-w-0 items-center gap-3">
                <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                </svg>
                <span class="min-w-0 break-all text-sm text-slate-700">@(string.IsNullOrEmpty(empleado.CuentaBancaria) ? "No disponible" : empleado.CuentaBancaria)</span>
            </div>
        </div>
    </div>

    @if (mostrarModalPerfil)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" @onclick="() => mostrarModalPerfil = false">
            <div class="relative w-full max-w-sm rounded-2xl bg-white p-6 text-center shadow-lg" @onclick:stopPropagation="true">
                <button type="button" @onclick="() => mostrarModalPerfil = false" class="absolute right-4 top-4 text-slate-900 hover:text-cormei">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <div class="relative mx-auto mb-3 h-16 w-16">
                    <svg class="h-16 w-16 text-slate-300" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                    <span class="@($"absolute bottom-0 right-1 h-4 w-4 rounded-full border-2 border-white {(EsActivo ? "bg-green-500" : "bg-slate-300")}")"></span>
                </div>

                <p class="break-words text-base font-bold uppercase text-cormei">@empleado.Nombres</p>
                <p class="mt-1 text-sm text-slate-700">Nro de hijos : @(empleado.NroHijos?.ToString() ?? "0")</p>

                <button type="button" @onclick="() => mostrarModalPerfil = false" class="mt-6 w-full rounded-xl bg-cormei py-3 text-sm font-bold text-white">Okay</button>
            </div>
        </div>
    }

    @if (mostrarModalCargo)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" @onclick="() => mostrarModalCargo = false">
            <div class="relative w-full max-w-sm rounded-2xl bg-white p-6 text-center shadow-lg" @onclick:stopPropagation="true">
                <button type="button" @onclick="() => mostrarModalCargo = false" class="absolute right-4 top-4 text-slate-900 hover:text-cormei">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <div class="relative mx-auto mb-3 h-16 w-16">
                    <svg class="h-16 w-16 text-slate-300" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                    <span class="@($"absolute bottom-0 right-1 h-4 w-4 rounded-full border-2 border-white {(EsActivo ? "bg-green-500" : "bg-slate-300")}")"></span>
                </div>

                <p class="text-sm text-slate-700">Categoria : @(string.IsNullOrEmpty(empleado.Categoria) ? "No disponible" : empleado.Categoria)</p>
                <p class="text-sm text-slate-700">Cargo : @(string.IsNullOrEmpty(empleado.Cargo) ? "No disponible" : empleado.Cargo)</p>
                <p class="text-sm text-slate-700">Sueldo bruto : @(empleado.Remuneracion?.ToString("0.0") ?? "No disponible")</p>
                <p class="text-sm text-slate-700">Bono fijo : @(empleado.BonoFijo?.ToString("0.0") ?? "No disponible")</p>

                <button type="button" @onclick="() => mostrarModalCargo = false" class="mt-6 w-full rounded-xl bg-cormei py-3 text-sm font-bold text-white">Okay</button>
            </div>
        </div>
    }

    @if (mostrarModalFechaNacimiento)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" @onclick="() => mostrarModalFechaNacimiento = false">
            <div class="relative w-full max-w-sm rounded-2xl bg-white p-6 text-center shadow-lg" @onclick:stopPropagation="true">
                <div class="flex items-center justify-between">
                    <h3 class="text-base font-bold text-cormei">Fecha de nacimiento</h3>
                    <button type="button" @onclick="() => mostrarModalFechaNacimiento = false" class="text-slate-900 hover:text-cormei">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <svg class="mx-auto mt-4 h-10 w-10 text-cormei" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2c-1.5 2-1.5 3 0 4-1.5 1-1.5 2 0 3H8v2h8v-2h-4c1.5-1 1.5-2 0-3 1.5-1 1.5-2 0-4zM4 12v7a2 2 0 002 2h12a2 2 0 002-2v-7H4zm2 2h2v2H6v-2zm4 0h2v2h-2v-2zm4 0h2v2h-2v-2z" />
                </svg>

                <p class="mt-4 text-base font-semibold text-slate-800">@(empleado.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "")</p>

                <button type="button" @onclick="() => mostrarModalFechaNacimiento = false" class="mt-6 w-full rounded-xl bg-cormei py-3 text-sm font-bold text-white">Okay</button>
            </div>
        </div>
    }
}