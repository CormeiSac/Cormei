@page "/postulacion"

<div class="flex min-h-screen w-full flex-col overflow-x-hidden bg-[#f4f7fb] font-sans text-slate-700">

    <div class="shrink-0 bg-[#a61d1d] px-4 py-3 text-white shadow-sm sm:px-6">
        <div class="mx-auto flex flex-col items-center justify-between gap-2 md:flex-row">
            <div class="flex items-center justify-center text-center md:w-52 md:justify-start md:text-left">
                <span class="text-xl font-bold tracking-wider text-white uppercase">CORMEI</span>
            </div>
            <div class="flex-1 text-center">
                <h1 class="text-lg font-bold tracking-wide md:text-xl">Ficha de postulante</h1>
                <p class="font-light text-[11px] text-red-100/90">Complete el formulario para unirse a nuestro equipo</p>
            </div>
            <div class="flex items-center justify-center gap-2 text-xs font-light text-red-100/80 md:w-52 md:justify-end">
                <svg class="h-3.5 w-3.5 shrink-0 text-red-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="whitespace-nowrap text-[11px]">Datos seguros y confidenciales</span>
            </div>
        </div>
    </div>

    <main class="mx-auto flex w-full max-w-7xl flex-grow flex-col gap-5 px-4 py-4 sm:px-6">

        <div class="flex flex-col gap-4">
            <div class="group relative flex min-h-[130px] flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 bg-white/70 p-5 text-center shadow-sm transition-all duration-300 hover:border-blue-400 hover:bg-blue-50/30 hover:shadow-md">

                <InputFile OnChange="OnInputFileChange" multiple accept=".pdf" class="absolute inset-0 z-20 h-full w-full cursor-pointer opacity-0" />

                <div class="pointer-events-none mb-2 flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600 transition-colors group-hover:bg-blue-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 0115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                </div>
                <p class="pointer-events-none text-sm font-bold text-slate-700">Arrastra tus PDFs aquí o haz clic para seleccionar</p>
                <p class="pointer-events-none mt-0.5 text-xs text-slate-400">Puedes subir uno o más archivos &middot; <span class="font-medium text-slate-500">PDFs de máx 10 MB c/u</span></p>
            </div>

            @if (archivosProcesados.Any())
            {
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var archivo in archivosProcesados)
                    {
                        <div class="flex items-center justify-between gap-3 rounded-xl border border-slate-200/80 bg-white p-3 shadow-sm transition hover:shadow-md">
                            <div class="flex items-center gap-2.5 overflow-hidden">
                                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red-50 text-red-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="truncate text-xs font-semibold text-slate-700" title="@archivo.Nombre">@archivo.Nombre</p>
                                    <p class="text-[10px] text-slate-400">@archivo.TamanoMegas</p>
                                </div>
                            </div>
                            <div class="flex shrink-0 items-center gap-2">
                                @if (archivo.Estado.StartsWith("Error"))
                                {
                                    <span class="inline-flex max-w-[120px] items-center truncate rounded-md bg-red-50 px-2 py-0.5 font-bold text-[10px] text-red-600" title="@archivo.Estado">@archivo.Estado</span>
                                }
                                else if (archivo.Estado == "Listo")
                                {
                                    <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-0.5 font-bold text-[10px] text-green-600">✓ Listo</span>
                                }
                                else
                                {
                                    <span class="inline-flex animate-pulse items-center rounded-md bg-blue-50 px-2 py-0.5 font-bold text-[10px] text-blue-600">@archivo.Estado</span>
                                }
                                <button type="button" @onclick="() => EliminarArchivo(archivo)" class="rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <form class="grid grid-cols-1 items-start gap-5 lg:grid-cols-2">
            <section class="rounded-2xl border border-slate-200/60 bg-white p-5 shadow-md">
                <div class="mb-4 border-b border-slate-100 pb-2">
                    <h2 class="text-xs font-black tracking-[0.15em] text-slate-400 uppercase">Identidad del Candidato</h2>
                    <p class="mt-0.5 text-xs text-slate-400">Información personal del postulante</p>
                </div>

                <div class="mb-4 flex items-center gap-4 rounded-xl border border-slate-100 bg-slate-50/50 p-3 shadow-sm">
                    <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white shadow-md">
                        <svg class="h-8 w-8 text-slate-300" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xs font-bold text-slate-700">Foto del candidato</h3>
                        <p class="mt-0.5 leading-tight text-[11px] text-slate-400">Opcional tipo carnet.</p>
                        <button type="button" class="mt-2 rounded-lg border border-blue-500 bg-white px-3 py-1 font-semibold text-[11px] text-blue-600 shadow-sm transition hover:bg-blue-50">Subir foto</button>
                    </div>
                </div>

                <div class="space-y-3.5">
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Nombres *</label>
                        <input type="text" @bind="txtNombres" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm transition hover:border-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                    </div>
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Apellidos *</label>
                        <input type="text" @bind="txtApellidos" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm transition hover:border-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                    </div>
                    <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2">
                        <div>
                            <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">DNI *</label>
                            <input type="text" @bind="txtDni" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                        </div>
                        <div>
                            <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Fecha de Nacimiento</label>
                            <input type="date" @bind="txtFechaNacimiento" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm text-slate-500 uppercase focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                        </div>
                    </div>
                    <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2">
                        <div>
                            <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Celular</label>
                            <input type="text" @bind="txtCelular" placeholder="9XXXXXXXX" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm placeholder-slate-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                        </div>
                        <div>
                            <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">E-mail</label>
                            <input type="email" @bind="txtEmail" placeholder="correo@ejemplo.com" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm placeholder-slate-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                        </div>
                    </div>
                </div>
            </section>

            <section class="rounded-2xl border border-slate-200/60 bg-white p-5 shadow-sm">
                <div class="mb-4 border-b border-slate-100 pb-2">
                    <h2 class="text-xs font-black tracking-[0.15em] text-slate-400 uppercase">Caracterización del CV</h2>
                    <p class="mt-0.5 text-xs text-slate-400">Perfil profesional y experiencia detectada</p>
                </div>

                <div class="space-y-3.5">
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Cargo Principal</label>
                        <input type="text" @bind="txtCargoPrincipal" placeholder="Ej: Soldador MIG, Operario CNC..." class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm placeholder-slate-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                        <span class="mt-0.5 block leading-none text-[11px] text-slate-400">Cargo predominante según experiencia reciente</span>
                    </div>
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Cargo Secundario</label>
                        <input type="text" @bind="txtCargoSecundario" placeholder="Ej: Tornero, Operario de Prensa..." class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm placeholder-slate-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                    </div>
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Otros Cargos</label>
                        <input type="text" @bind="txtOtrosCargos" placeholder="Separados por coma" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm placeholder-slate-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                    </div>
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Experiencia General</label>
                        <select @bind="txtExperienciaGeneral" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm text-slate-600 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none">
                            <option value="" disabled selected>Seleccionar...</option>
                            <option value="Menos de 1 año">Menos de 1 año</option>
                            <option value="1 a 3 años">1 a 3 años</option>
                            <option value="3 a 5 años">3 a 5 años</option>
                            <option value="Más de 5 años">Más de 5 años</option>
                        </select>
                    </div>
                    <div>
                        <label class="mb-1 block font-bold tracking-wider text-[11px] text-slate-500 uppercase">Conocimientos / Cursos</label>
                        <textarea rows="3" @bind="txtConocimientosCursos" placeholder="Certificaciones o cursos clave..." class="w-full resize-none rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-sm transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100 focus:outline-none"></textarea>
                    </div>
                </div>
            </section>

            <div class="flex w-full items-center justify-center lg:col-span-2">
                <button type="submit" class="group/btn flex w-full min-w-[240px] items-center justify-center gap-2 rounded-xl bg-[#a61d1d] px-6 py-3 text-sm font-bold tracking-wide text-white shadow-md transition-all duration-200 hover:bg-[#8b1414] hover:shadow-lg focus:ring-4 focus:ring-red-100 focus:outline-none sm:w-auto">
                    <span>Enviar Postulación</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-3 transition-transform duration-200 group-hover/btn:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </button>
            </div>
        </form>

    </main>

    <footer class="mt-auto shrink-0 border-t border-slate-200 bg-white/80 px-4 py-4 backdrop-blur sm:px-6">
        <div class="mx-auto flex items-center justify-between gap-2 text-center md:flex-row">
            <div class="text-[11px] text-slate-400">&copy; 2026 <span class="font-bold tracking-wider text-slate-500 uppercase">Cormei</span> &middot; Todos los derechos reservados</div>
            <div class="flex items-center gap-4 text-[11px] text-slate-400">
                <a href="#" class="transition hover:text-blue-600">Soporte Técnico</a>
                <span class="text-slate-300">|</span>
                <a href="#" class="transition hover:text-blue-600">Políticas de Privacidad</a>
            </div>
        </div>
    </footer>
</div>