@page "/escaneo/resultado"
@layout LoginLayout

<PageTitle>Resultado del Escaneo · CORMEI</PageTitle>

<div class="flex h-screen w-full flex-col overflow-hidden bg-[#f4f7fb] pt-[env(safe-area-inset-top)] font-sans text-slate-700">

    <header class="flex h-16 shrink-0 items-center justify-between border-b border-slate-200 bg-white px-4 sm:px-6">
        <h1 class="text-xl font-bold text-slate-900">Resultado del Escaneo</h1>
        <button type="button" title="Escanear otro" @onclick="EscanearOtroAsync" class="flex h-9 w-9 items-center justify-center rounded-lg text-slate-900 hover:bg-slate-100">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="2" height="2" fill="currentColor" stroke="none" />
                <rect x="18" y="14" width="3" height="3" fill="currentColor" stroke="none" />
                <rect x="14" y="18" width="3" height="3" fill="currentColor" stroke="none" />
                <rect x="19" y="19" width="2" height="2" fill="currentColor" stroke="none" />
            </svg>
        </button>
    </header>

    <main class="relative flex-1 overflow-y-auto p-4 sm:p-6">
        @if (resultado is null)
        {
            <div class="mx-auto flex max-w-md flex-col items-center gap-4 rounded-2xl border border-dashed border-slate-300 bg-white/60 p-10 text-center">
                <p class="text-sm text-slate-500">No hay ningún resultado. Escanea un código QR para ver la información.</p>
                <button type="button" @onclick="EscanearOtroAsync" class="rounded-xl bg-cormei px-6 py-3 text-sm font-bold text-white">Escanear QR</button>
            </div>
        }
        else
        {
            <div class="mx-auto flex max-w-md flex-col gap-4">

                <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="flex items-center gap-4">
                        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-slate-300">
                            <svg class="h-9 w-9 text-slate-100" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                            </svg>
                        </div>
                        <p class="break-words font-bold uppercase text-slate-900">@resultado.Nombres</p>
                    </div>

                    <hr class="my-3 border-slate-200" />

                    <div class="space-y-2 text-sm">
                        <div class="flex items-center justify-between gap-3">
                            <span class="text-slate-500">Documento:</span>
                            <span class="text-right font-semibold text-slate-700">@resultado.Documento</span>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <span class="text-slate-500">Cargo:</span>
                            <span class="text-right font-semibold text-slate-700">@resultado.Cargo</span>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <span class="text-slate-500">Categoría:</span>
                            <span class="text-right font-semibold text-slate-700">@resultado.Categoria</span>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <span class="text-slate-500">Área:</span>
                            <span class="text-right font-semibold text-slate-700">@resultado.Area</span>
                        </div>
                        <div class="flex items-center justify-between gap-3">
                            <span class="text-slate-500">Sede:</span>
                            <span class="text-right font-semibold text-slate-700">@resultado.Sede</span>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(resultado.Iperc))
                {
                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <p class="mb-2 font-bold text-slate-900">Documentos</p>
                        <button type="button" @onclick="() => AbrirDocumentoAsync(resultado.Iperc)"
                                class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 py-3 text-sm font-bold text-cormei hover:bg-slate-50">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12h-9a1.5 1.5 0 01-1.5-1.5V5.25a1.5 1.5 0 011.5-1.5h4.5l6 6v6a1.5 1.5 0 01-1.5 1.5z" />
                            </svg>
                            ABRIR PDF DE IPERC
                        </button>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(resultado.Politica))
                {
                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <p class="mb-2 font-bold text-slate-900">Políticas y Privacidad</p>
                        <button type="button" @onclick="() => AbrirDocumentoAsync(resultado.Politica)"
                                class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-200 py-3 text-sm font-bold text-cormei hover:bg-slate-50">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.75h-.152c-3.196 0-6.1-1.248-8.25-3.286z" />
                            </svg>
                            VER POLÍTICAS DE PRIVACIDAD
                        </button>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(resultado.MatrizAmbiente))
                {
                    <button type="button" @onclick="() => AbrirDocumentoAsync(resultado.MatrizAmbiente)"
                            class="rounded-2xl border border-slate-200 bg-white p-4 text-left font-bold text-slate-900 shadow-sm hover:bg-slate-50">
                        Matriz Ambiental
                    </button>
                }

                @if (!string.IsNullOrWhiteSpace(resultado.RespuestaEmergencia))
                {
                    <button type="button" @onclick="() => AbrirDocumentoAsync(resultado.RespuestaEmergencia)"
                            class="rounded-2xl border border-slate-200 bg-white p-4 text-left font-bold text-slate-900 shadow-sm hover:bg-slate-50">
                        Plan de Respuesta a Emergencias
                    </button>
                }

                @if (!string.IsNullOrWhiteSpace(resultado.HojaSds))
                {
                    <button type="button" @onclick="() => AbrirDocumentoAsync(resultado.HojaSds)"
                            class="rounded-2xl border border-slate-200 bg-white p-4 text-left font-bold text-slate-900 shadow-sm hover:bg-slate-50">
                        Hoja SDS
                    </button>
                }
            </div>
        }

        <button type="button" title="Cerrar" @onclick="CerrarAsync"
                class="fixed bottom-6 right-6 flex h-14 w-14 items-center justify-center rounded-full bg-cormei text-white shadow-lg active:scale-95">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </main>
</div>