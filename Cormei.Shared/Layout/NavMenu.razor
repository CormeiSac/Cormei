@using Cormei.Core.Services.Login
@inject AuthState AuthState
@inject NavigationManager NavigationManager

<aside class="@($"fixed inset-y-0 left-0 z-40 flex w-[260px] shrink-0 flex-col overflow-hidden shadow-2xl transition-transform duration-300 lg:static lg:translate-x-0 {(MenuAbierto ? "translate-x-0" : "-translate-x-full")}")">

    <img src="_content/Cormei.Shared/images/bg_side_menu.png" alt="" class="absolute inset-0 h-full w-full object-cover" />

    <div class="relative z-10 flex h-16 shrink-0 items-center border-b border-white/10 px-5">
        <img src="_content/Cormei.Shared/images/ic_logo_white.png" alt="Logo CORMEI" class="h-8 w-auto object-contain" />
    </div>

    <nav class="relative z-10 flex-1 overflow-y-auto py-2">

        <NavLink href="marcacion-remota" @onclick="Navegar" class="group flex items-center gap-4 border-l-4 border-transparent px-6 py-4 text-sm font-semibold text-slate-300 transition-colors hover:border-l-cormei hover:bg-white/5 hover:text-white" ActiveClass="border-l-cormei bg-white/10 text-white">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            Marcación remota
        </NavLink>

        <NavLink href="empleados" @onclick="Navegar" class="group flex items-center gap-4 border-l-4 border-transparent px-6 py-4 text-sm font-semibold text-slate-300 transition-colors hover:border-l-cormei hover:bg-white/5 hover:text-white" ActiveClass="border-l-cormei bg-white/10 text-white">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            Lista de empleados
        </NavLink>

        <NavLink href="actividades" @onclick="Navegar" class="group flex items-center gap-4 border-l-4 border-transparent px-6 py-4 text-sm font-semibold text-slate-300 transition-colors hover:border-l-cormei hover:bg-white/5 hover:text-white" ActiveClass="border-l-cormei bg-white/10 text-white">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75M3.75 6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 6.108V6c0-.552-.448-1-1-1h-1.5c-.552 0-1 .448-1 1v.108m3 0h-3m3 0h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25H6.375A2.25 2.25 0 014.125 18V7.233c0-.621.504-1.125 1.125-1.125h3.375" />
            </svg>
            Actividades
        </NavLink>
    </nav>

    <div class="relative z-10 shrink-0 p-5">
        <button type="button" @onclick="CerrarSesion" class="flex w-full items-center justify-center gap-2 rounded-lg bg-white px-4 py-3 text-sm font-black text-cormei shadow-xl transition-transform hover:scale-105 active:scale-95">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l3 3m0 0l-3 3m3-3H2.25" />
            </svg>
            Cerrar sesión
        </button>
    </div>
</aside>

@code {
    [Parameter] public bool MenuAbierto { get; set; }
    [Parameter] public EventCallback CerrarMenu { get; set; }

    private async Task Navegar()
    {
        if (CerrarMenu.HasDelegate)
        {
            await CerrarMenu.InvokeAsync();
        }
    }

    private void CerrarSesion()
    {
        AuthState.ClearSession();
        NavigationManager.NavigateTo("/login");
    }
}
